{
  "manifest_version": 3,
  "name": "LifeCycle V1",
  "description": "Track active tab time and show one baseline insight.",
  "version": "1.0.0",
  "permissions": ["alarms", "idle", "notifications", "scripting", "storage", "tabs", "windows"],
  "host_permissions": ["http://127.0.0.1:8000/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LifeCycle",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
